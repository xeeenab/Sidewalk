{
  "name": "sidewalk",
  "version": "1.0.0",
  "description": "**Sidewalk** is an open-source, civic reporting and accountability platform that empowers citizens to document local issues, track government response, and ensure follow-through—publicly and transparently.",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "dev:api": "pnpm --filter sidewalk-api dev",
    "dev:web": "pnpm --filter sidewalk-web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mixmatch/Sidewalk.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Mixmatch/Sidewalk/issues"
  },
  "homepage": "https://github.com/Mixmatch/Sidewalk#readme"
}
